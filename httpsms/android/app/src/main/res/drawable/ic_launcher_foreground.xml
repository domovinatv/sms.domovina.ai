<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">
    <!-- Domovina D-logo, scaled into the safe zone for adaptive launcher icon.
         108dp safe zone is the inner 66dp circle; the path itself already
         occupies ~72% of the 512 viewport, so 0.65 keeps the logo comfortably
         inside that safe zone with launcher-typical padding around it. -->
    <group android:pivotX="256" android:pivotY="256" android:scaleX="0.65" android:scaleY="0.65">
        <!-- D-shape filled with vertical Croatian tricolour gradient -->
        <path android:pathData="M72,64 H248 C354.071,64 440,149.929 440,256 C440,362.071 354.071,448 248,448 H72 V64 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="256" android:startY="64"
                    android:endX="256" android:endY="448">
                    <item android:offset="0.0" android:color="#FFFF0000"/>
                    <item android:offset="0.3333" android:color="#FFFF0000"/>
                    <item android:offset="0.3333" android:color="#FFFFFFFF"/>
                    <item android:offset="0.6666" android:color="#FFFFFFFF"/>
                    <item android:offset="0.6666" android:color="#FF002F6C"/>
                    <item android:offset="1.0" android:color="#FF002F6C"/>
                </gradient>
            </aapt:attr>
        </path>
        <!-- Inner D carve-out (white) -->
        <path
            android:pathData="M168,160 H248 C301.019,160 344,202.981 344,256 C344,309.019 301.019,352 248,352 H168 V160 Z"
            android:fillColor="#FFFFFFFF"/>
        <!-- AI graph edges (8 line segments) -->
        <path
            android:pathData="M205,205 L295,225 M295,225 L285,285 M285,285 L205,307 M205,307 L205,205 M205,205 L245,256 M295,225 L245,256 M285,285 L245,256 M205,307 L245,256"
            android:strokeColor="#FF002F6C"
            android:strokeWidth="5"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"/>
        <!-- AI graph nodes: 4 outer (r=10) + 1 center (r=14) -->
        <path
            android:pathData="M195,205 a10,10 0,1,0 20,0 a10,10 0,1,0 -20,0 Z"
            android:fillColor="#FF002F6C"/>
        <path
            android:pathData="M285,225 a10,10 0,1,0 20,0 a10,10 0,1,0 -20,0 Z"
            android:fillColor="#FF002F6C"/>
        <path
            android:pathData="M195,307 a10,10 0,1,0 20,0 a10,10 0,1,0 -20,0 Z"
            android:fillColor="#FF002F6C"/>
        <path
            android:pathData="M275,285 a10,10 0,1,0 20,0 a10,10 0,1,0 -20,0 Z"
            android:fillColor="#FF002F6C"/>
        <path
            android:pathData="M231,256 a14,14 0,1,0 28,0 a14,14 0,1,0 -28,0 Z"
