# ──────────────────────────────────────────────────────────────────────────
# Coolify deployment env vars for sms.domovina.ai (httpsms)
# Copy these into Coolify "Environment Variables" tab. Mark secrets as Secret.
# ──────────────────────────────────────────────────────────────────────────

# ── Public URLs (Cloudflare Tunnel hostnames) ──
# These are the public URLs you map via Cloudflare Tunnel to the api/web containers.
APP_URL=https://sms.domovina.ai
API_BASE_URL=https://sms-api.domovina.ai
SWAGGER_HOST=sms-api.domovina.ai
APP_NAME=domovina.ai SMS

# ── Postgres ──
POSTGRES_DB=httpsms
POSTGRES_USER=httpsms
POSTGRES_PASSWORD=change-me-strong-random

# ── Firebase (server) ──
# GCP project id of your Firebase project.
GCP_PROJECT_ID=
# Full JSON of the Firebase service account, on a single line (escape newlines as \n).
FIREBASE_CREDENTIALS=

# ── Firebase (web client, baked into static build) ──
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ── SMTP (for transactional email / login links) ──
SMTP_FROM_NAME=domovina.ai SMS
SMTP_FROM_EMAIL=no-reply@domovina.ai
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587

# ── Events queue (system user — must exist in DB after first migration) ──
# After first deploy: create a row in `users` table, put its id and api_key here, redeploy.
EVENTS_QUEUE_USER_ID=
EVENTS_QUEUE_USER_API_KEY=

# ── Optional ──
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
CHECKOUT_URL=
ENTERPRISE_CHECKOUT_URL=
